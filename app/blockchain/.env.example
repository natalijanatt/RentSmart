# Solana network
SOLANA_RPC_URL=http://127.0.0.1:8899
# For devnet: https://api.devnet.solana.com

# Program ID — obtained after: anchor deploy --provider.cluster devnet
SOLANA_PROGRAM_ID=

# Authority keypair — JSON array of 64 bytes
# Generate: solana-keygen new --outfile ~/.config/solana/rentsmart-authority.json
# Export:   cat ~/.config/solana/rentsmart-authority.json
SOLANA_AUTHORITY_KEYPAIR=

# EUR/SOL exchange rate (optional — defaults to 0.01 for devnet demos)
# In production, fetch from a price oracle
EUR_SOL_RATE=

# Anchor tooling (used by tests)
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899
ANCHOR_WALLET=~/.config/solana/id.json
