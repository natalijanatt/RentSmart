# PostgreSQL connection string from Supabase
# Project Settings > Database > Connection string > URI
# Use Transaction Pooler (port 6543) for serverless/edge, direct (port 5432) for persistent
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase project URL, service role key, and anon key
# Project Settings > API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Server
PORT=3000
NODE_ENV=development

# Set to true to skip Firebase token verification in development
MOCK_AUTH=true

# Set to true to skip Gemini LLM calls in development
MOCK_LLM=true

# Optional: Solana program ID (leave unset to use mock Solana service)
# SOLANA_PROGRAM_ID=

# Firebase Admin SDK — required when MOCK_AUTH=false
# Service Account > Generate new private key
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Gemini — required when MOCK_LLM=false
# GEMINI_API_KEY=
