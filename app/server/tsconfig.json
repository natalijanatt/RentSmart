{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "..",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "paths": {
      "@rentsmart/contracts": [
        "../packages/contracts/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "../packages/contracts/src"
  ]
}
